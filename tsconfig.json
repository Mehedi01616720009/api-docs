{
    "compilerOptions": {
        /* Language and Environment */
        "target": "es2016",
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,

        /* Modules */
        "module": "commonjs",
        "rootDir": "./src",

        /* Emit */
        "outDir": "./dist",

        /* Interop Constraints */
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,

        /* Type Checking */
        "strict": true,

        /* Completeness */
        "skipLibCheck": true,
        "declaration": true,
        "emitDeclarationOnly": false
    },
    "include": ["./src"]
}
